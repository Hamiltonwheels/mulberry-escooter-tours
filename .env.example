# Mulberry E-Scooter Tours  Environment Configuration
# Copy to .env and fill in your values

# App Secret (generate a random string for production)
SECRET_KEY=change-me-to-a-random-string

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite:///escooter_tours.db

# Stripe Keys (get from https://dashboard.stripe.com/apikeys)
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Business Info
BUSINESS_EMAIL=info@mulberryscootertours.com
BUSINESS_PHONE=(706) 555-0199

# Email (SMTP  Gmail example)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@mulberryscootertours.com
